{
  "info": {
    "name": "Tap Payments API",
    "description": "REST API for Tap Payments, a payment gateway for the Middle East and North Africa. Base URL: https://api.tap.company/v2. Authenticate with a secret API key as a Bearer token (test keys sk_test_..., live keys sk_live_...). Endpoint paths and methods are grounded in Tap's public developer reference and OpenAPI index (developers.tap.company/llms.txt); example request bodies are representative.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{secretApiKey}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.tap.company/v2", "type": "string" },
    { "key": "secretApiKey", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Charges",
      "item": [
        {
          "name": "Create a charge",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 1,\n  \"currency\": \"KWD\",\n  \"threeDSecure\": true,\n  \"customer\": { \"first_name\": \"Test\", \"email\": \"test@example.com\" },\n  \"source\": { \"id\": \"src_card\" },\n  \"redirect\": { \"url\": \"https://example.com/return\" }\n}" },
            "url": { "raw": "{{baseUrl}}/charges", "host": ["{{baseUrl}}"], "path": ["charges"] },
            "description": "Initiates a charge to charge a card or other payment source."
          }
        },
        {
          "name": "List all charges",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/charges", "host": ["{{baseUrl}}"], "path": ["charges"] },
            "description": "Lists charges, filterable by date, status, method, customer, and charge id."
          }
        },
        {
          "name": "Retrieve a charge",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/charges/:charge_id", "host": ["{{baseUrl}}"], "path": ["charges", ":charge_id"], "variable": [{ "key": "charge_id", "value": "" }] },
            "description": "Retrieves the details of a charge by its id."
          }
        },
        {
          "name": "Update a charge",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\"\n}" },
            "url": { "raw": "{{baseUrl}}/charges/:charge_id", "host": ["{{baseUrl}}"], "path": ["charges", ":charge_id"], "variable": [{ "key": "charge_id", "value": "" }] },
            "description": "Updates mutable fields on a charge (modeled: verify method against the live reference)."
          }
        }
      ]
    },
    {
      "name": "Authorize",
      "item": [
        {
          "name": "Create an authorize",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 1,\n  \"currency\": \"KWD\",\n  \"customer\": { \"first_name\": \"Test\", \"email\": \"test@example.com\" },\n  \"source\": { \"id\": \"src_card\" },\n  \"redirect\": { \"url\": \"https://example.com/return\" }\n}" },
            "url": { "raw": "{{baseUrl}}/authorize", "host": ["{{baseUrl}}"], "path": ["authorize"] },
            "description": "Authorizes (holds) funds on a card without capturing."
          }
        },
        {
          "name": "Retrieve an authorize",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/authorize/:authorize_id", "host": ["{{baseUrl}}"], "path": ["authorize", ":authorize_id"], "variable": [{ "key": "authorize_id", "value": "" }] },
            "description": "Retrieves an authorize object by its id."
          }
        }
      ]
    },
    {
      "name": "Refunds",
      "item": [
        {
          "name": "Create a refund",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"charge_id\": \"chg_XXXX\",\n  \"amount\": 1,\n  \"currency\": \"KWD\",\n  \"reason\": \"requested_by_customer\"\n}" },
            "url": { "raw": "{{baseUrl}}/refunds", "host": ["{{baseUrl}}"], "path": ["refunds"] },
            "description": "Issues a full or partial refund against a captured charge."
          }
        },
        {
          "name": "List all refunds",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/refunds", "host": ["{{baseUrl}}"], "path": ["refunds"] },
            "description": "Lists refunds, filterable by charge and date."
          }
        }
      ]
    },
    {
      "name": "Customers",
