          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"email\": \"test@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/customers", "host": ["{{baseUrl}}"], "path": ["customers"] },
            "description": "Creates a customer record used to save cards and reconcile future charges."
          }
        },
        {
          "name": "Retrieve a customer",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/customers/:customer_id", "host": ["{{baseUrl}}"], "path": ["customers", ":customer_id"], "variable": [{ "key": "customer_id", "value": "" }] },
            "description": "Retrieves a customer by id."
          }
        },
        {
          "name": "List all customers",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/customers", "host": ["{{baseUrl}}"], "path": ["customers"] },
            "description": "Lists customers in the account."
          }
        }
      ]
    },
    {
      "name": "Tokens",
      "item": [
        {
          "name": "Create a token (card)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"card\": {\n    \"number\": \"5123450000000008\",\n    \"exp_month\": 5,\n    \"exp_year\": 27,\n    \"cvc\": \"100\",\n    \"name\": \"Test User\"\n  }\n}" },
            "url": { "raw": "{{baseUrl}}/tokens", "host": ["{{baseUrl}}"], "path": ["tokens"] },
            "description": "Tokenizes raw card data into a single-use token id. Tokens cannot be stored or reused."
          }
        },
        {
          "name": "Retrieve a token",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/tokens/:token_id", "host": ["{{baseUrl}}"], "path": ["tokens", ":token_id"], "variable": [{ "key": "token_id", "value": "" }] },
            "description": "Retrieves a token by its id."
          }
        }
      ]
    },
    {
      "name": "Cards",
      "item": [
        {
          "name": "List all cards",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/card/:customer_id", "host": ["{{baseUrl}}"], "path": ["card", ":customer_id"], "variable": [{ "key": "customer_id", "value": "" }] },
            "description": "Lists the saved cards (card-on-file) stored against a customer (modeled path)."
          }
        },
        {
          "name": "Retrieve a card",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/card/:customer_id/:card_id", "host": ["{{baseUrl}}"], "path": ["card", ":customer_id", ":card_id"], "variable": [{ "key": "customer_id", "value": "" }, { "key": "card_id", "value": "" }] },
            "description": "Retrieves a saved card by id for a given customer (modeled path)."
          }
        },
        {
          "name": "Delete a card",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/card/:customer_id/:card_id", "host": ["{{baseUrl}}"], "path": ["card", ":customer_id", ":card_id"], "variable": [{ "key": "customer_id", "value": "" }, { "key": "card_id", "value": "" }] },
            "description": "Deletes a saved card from a customer (modeled path)."
          }
        }
      ]
    },
    {
