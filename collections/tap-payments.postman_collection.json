            "body": { "mode": "raw", "raw": "{\n  \"amount\": 10,\n  \"currency\": \"KWD\",\n  \"customer\": { \"first_name\": \"Test\", \"email\": \"test@example.com\" }\n}" },
            "url": { "raw": "{{baseUrl}}/invoices", "host": ["{{baseUrl}}"], "path": ["invoices"] },
            "description": "Creates a hosted invoice that produces a payable link delivered by email or SMS."
          }
        },
        {
          "name": "List all invoices",
          "request": {
            "method": "GET",
